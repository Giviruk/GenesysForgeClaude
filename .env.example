# Скопируйте в .env и поменяйте значения (обязательно для VPS!)
# cp .env.example .env

# Порт, на котором будет доступен сайт
WEB_PORT=8080

# Пароль PostgreSQL (данные хранятся в docker-томе pgdata)
POSTGRES_PASSWORD=change-me-strong-db-password

# Публиковать ли порт Postgres наружу (для локальной отладки); на VPS лучше не открывать
POSTGRES_PORT=5432

# Ключ подписи JWT — минимум 32 символа, сгенерируйте случайный:
#   openssl rand -base64 48
JWT_KEY=change-me-min-32-chars-random-secret-key!!

# Окружение API: Production | Development
API_ENVIRONMENT=Production

# Google OAuth (опционально, отложено для приватного MVP). Оставьте пустым — вход через Google
# выключен и кнопка скрыта. Чтобы включить: создайте OAuth client (Web) в Google Cloud,
# добавьте origin сайта в Authorized JavaScript origins и впишите client id сюда.
GOOGLE_CLIENT_ID=
