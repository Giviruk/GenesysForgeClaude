# Скопируйте в .env и поменяйте значения (обязательно для VPS!)
# cp .env.example .env

# Порт, на котором будет доступен сайт
WEB_PORT=8080

# Пароль PostgreSQL (данные хранятся в docker-томе pgdata)
POSTGRES_PASSWORD=change-me-strong-db-password

# Публиковать ли порт Postgres наружу (для локальной отладки); на VPS лучше не открывать
POSTGRES_PORT=5432

# Ключ подписи JWT — минимум 32 символа, сгенерируйте случайный:
#   openssl rand -base64 48
JWT_KEY=change-me-min-32-chars-random-secret-key!!

# Время жизни access-токена в минутах. Короткое, т.к. сессия продлевается refresh-токеном
# (HttpOnly-cookie, ротация при каждом обновлении, отзыв семейства при повторном использовании).
JWT_ACCESS_LIFETIME_MINUTES=30

# Auth rate limits per client IP / fixed window.
AUTH_SENSITIVE_PERMIT_LIMIT=10
AUTH_SESSION_PERMIT_LIMIT=30
AUTH_PUBLIC_PERMIT_LIMIT=60
AUTH_RATE_WINDOW_SECONDS=60

# Production hostnames. PrivateFull and PublicSafe use separate API/database stacks.
PRIVATE_HOSTNAME=private.example.com
# Without a real value the deploy workflow uses public-disabled.localhost, so public access stays off.
PUBLIC_HOSTNAME=public.example.com

# Number of days kept by the automatic pg_dump service.
BACKUP_RETENTION_DAYS=14

# Базовый адрес сайта для ссылок в письмах (сброс пароля). В prod compose берётся из
# PRIVATE_HOSTNAME/PUBLIC_HOSTNAME автоматически; для локального запуска можно задать здесь.
APP_BASE_URL=http://localhost:8080

# Email-провайдер для писем сброса пароля.
#   Logging (по умолчанию) — ничего не отправляет, пишет ссылку в лог API (для dev).
#   Smtp                  — реальная отправка через SMTP-relay (MailKit).
EMAIL_PROVIDER=Logging
# Адрес и имя отправителя (From). По умолчанию no-reply@<hostname>.
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=GenesysForge
# Параметры SMTP-relay (нужны только при EMAIL_PROVIDER=Smtp). Подходит собственный сервер
# или SMTP-режим Resend/SendGrid/Mailgun. Порт 587 + STARTTLS — типовой; для 465 (implicit TLS)
# выставьте EMAIL_SMTP_USE_STARTTLS=false.
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_STARTTLS=true

# S3-хранилище картинок (аватары пользователей, портреты персонажей).
#   None (по умолчанию) — загрузка файлов выключена, аватар можно задать только внешним URL.
#   S3                  — S3-совместимое хранилище (Beget Cloud Storage, MinIO, AWS).
# Бакет может быть общим с другими проектами: приложение пишет строго под префиксом
# genesysforge/uploads/<private|public> (задан в docker-compose.prod.yml) и удаляет только своё.
STORAGE_PROVIDER=None
S3_SERVICE_URL=https://s3.ru1.storage.beget.cloud
S3_BUCKET=
S3_REGION=ru1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Требовать подтверждённый e-mail для входа (для публичного запуска). По умолчанию выключено —
# приватный MVP вход не блокирует.
REQUIRE_EMAIL_CONFIRMATION=false

# Google OAuth (опционально, отложено для приватного MVP). Оставьте пустым — вход через Google
# выключен и кнопка скрыта. Чтобы включить: создайте OAuth client (Web) в Google Cloud,
# добавьте origin сайта в Authorized JavaScript origins и впишите client id сюда.
GOOGLE_CLIENT_ID=
