# Caddy терминирует TLS для Cloudflare origin (Cloudflare Origin Certificate, режим SSL «Full (strict)»)
# и проксирует на web-контейнер (nginx), который раздаёт SPA и сам проксирует /api на api-контейнер.
# ACME/Let's Encrypt НЕ используется: сертификат origin выпущен Cloudflare и лежит в /etc/caddy/certs
# (deploy-workflow пишет его на сервер из GitHub Secrets). PrivateFull и PublicSafe работают раздельно:
# разные API-контейнеры и базы данных.
{
	# Явные сертификаты — авто-ACME не нужен; отключаем автоматический HTTP→HTTPS редирект,
	# им управляет Cloudflare (Always Use HTTPS). Origin слушает 443, к нему ходит только Cloudflare.
	auto_https disable_redirects
}

{$PRIVATE_HOSTNAME} {
	encode gzip
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key
	reverse_proxy web:80
}

{$PUBLIC_HOSTNAME} {
	encode gzip
	tls /etc/caddy/certs/origin.crt /etc/caddy/certs/origin.key
	reverse_proxy web-public:80
}
