# Caddy терминирует TLS (Let's Encrypt) и проксирует на web-контейнер (nginx),
# который раздаёт SPA и сам проксирует /api на api-контейнер.
# Сейчас деплоим только private-версию (ContentMode=PrivateFull) на PRIVATE_HOSTNAME.
# Публичный хост добавим позже отдельным блоком, когда будет готов PublicSafe-стек.
{
	email {$LETSENCRYPT_EMAIL}
}

{$PRIVATE_HOSTNAME} {
	encode gzip
	reverse_proxy web:80
}
