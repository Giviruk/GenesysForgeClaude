# Caddy терминирует TLS (Let's Encrypt) и проксирует на web-контейнер (nginx),
# который раздаёт SPA и сам проксирует /api на api-контейнер.
# PrivateFull и PublicSafe работают раздельно: разные API-контейнеры и базы данных.
{
	email {$LETSENCRYPT_EMAIL}
}

{$PRIVATE_HOSTNAME} {
	encode gzip
	reverse_proxy web:80
}

{$PUBLIC_HOSTNAME} {
	encode gzip
	reverse_proxy web-public:80
}
